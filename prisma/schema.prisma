generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  COACH
  ATHLETE
}

model User {
  id            Int   @unique @default(autoincrement())
  name          String 
  surname       String
  age           Int
  weight        Float
  phone         String
  role          Role @default(ATHLETE)
  imageUri      String

  stat          Stats[]

  email         String
  password      String
}

model Stats {
  id            Int @unique @default(autoincrement())

  user          User  @relation(fields: [userId],references: [id])
  userId        Int
  
  squat         Int
  bench         Int
  deadlift      Int
}