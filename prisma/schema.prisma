generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  COACH
  ATHLETE_PROG
  ATHLETE_CO
  ATHLETE_FULL
  ADMIN
}

model User {
  id       Int     @id @default(autoincrement())
  name     String
  surname  String
  age      Int
  weight   Float
  phone    String
  role     Role
  imageUri String

  progUri       Program[]
  stat          Stats[]
  courses       Courses[]      @relation("CoachCourses")
  registrations Registration[]

  email    String @unique
  password String
}

model Stats {
  id Int @id @default(autoincrement())

  user   User @relation(fields: [userId], references: [id])
  userId Int

  squat    Float
  bench    Float
  deadlift Float
}

model Courses {
  id              Int      @id @default(autoincrement())
  title           String
  description     String?
  startAt         DateTime
  durationMinutes Int
  maxParticipants Int

  coachId Int?
  coach   User? @relation("CoachCourses", fields: [coachId], references: [id])

  registrations Registration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([coachId])
  @@index([startAt])
}

model Registration {
  id       Int @id @default(autoincrement())
  userId   Int
  courseId Int

  user   User    @relation(fields: [userId], references: [id])
  course Courses @relation(fields: [courseId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, courseId])
  @@index([courseId])
}

model Program {
  id Int @id @default(autoincrement())
  name String
  fileUri String

  userId Int
  user   User @relation(fields: [userId], references: [id])
}