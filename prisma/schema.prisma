generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
}

model Role {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  users       User[]
}

model User {
  id       Int     @id @default(autoincrement())
  name     String
  surname  String
  age      Int
  weight   Float
  phone    String
  roleId   String
  role     Role    @relation(fields: [roleId], references: [id])
  imageUri String

  progUri       Program[]
  stat          Stats[]
  courses       Courses[]      @relation("CoachCourses")
  registrations Registration[]
  payments      PaymentYear[]
  refreshTokens RefreshToken[]
  orders        Order[]

  username  String @unique
  password  String
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PaymentYear {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  year      Int
  status    Json
  updatedAt DateTime @updatedAt

  @@unique([userId, year])
}

model Stats {
  id Int @id @default(autoincrement())

  user   User @relation(fields: [userId], references: [id])
  userId Int

  squat    Float
  bench    Float
  deadlift Float
}

model Courses {
  id              Int      @id @default(autoincrement())
  title           String
  description     String?
  startAt         DateTime
  durationMinutes Int
  maxParticipants Int

  coachId Int?
  coach   User? @relation("CoachCourses", fields: [coachId], references: [id])

  registrations Registration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([coachId])
  @@index([startAt])
}

model Registration {
  id       Int @id @default(autoincrement())
  userId   Int
  courseId Int

  user   User    @relation(fields: [userId], references: [id])
  course Courses @relation(fields: [courseId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, courseId])
  @@index([courseId])
}

model Program {
  id Int @id @default(autoincrement())
  name String
  fileUri String

  userId Int
  user   User @relation(fields: [userId], references: [id])
}

model Product {
  id         Int            @id @default(autoincrement())
  name       String
  price      Float          @default(0)
  imageUri   String         @default("productImage/default.png")
  stocks     ProductStock[]
  orderItems OrderItem[]
}

model ProductStock {
  id        Int     @id @default(autoincrement())
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  size      String
  quantity  Int     @default(0)

  @@unique([productId, size])
}

model Order {
  id        Int         @id @default(autoincrement())
  userId    Int
  user      User        @relation(fields: [userId], references: [id])
  items     OrderItem[]
  total     Float
  status    String      @default("PENDING") // PENDING, COMPLETED, CANCELLED
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  size      String
  quantity  Int
  price     Float
}