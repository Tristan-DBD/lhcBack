// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int   @unique @default(autoincrement())
  name        String 
  surname     String
  age         Int
  weight      Float

  stat        Stats[]

  email       String
  password    String
}

model Stats {
  id          Int @unique @default(autoincrement())

  user        User  @relation(fields: [userId],references: [id])
  userId      Int
  
  squat       Int
  bench       Int
  deadlift    Int
}