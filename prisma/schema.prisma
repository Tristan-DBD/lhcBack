generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
}

// ─────────────────────────────────────────────
// AUTH & USERS
// ─────────────────────────────────────────────

model Role {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  users       User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id       String  @id @default(uuid())
  name     String
  surname  String
  age      Int
  weight   Float
  phone    String
  imageUri String

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  username String @unique
  password String

  // Relations
  programs      Program[]
  stats         Stats[]
  courses       Course[]       @relation("CoachCourses")
  registrations Registration[]
  payments      PaymentYear[]
  refreshTokens RefreshToken[]
  orders        Order[]
  coachingSlots CoachingSlot[] @relation("CoachSlots")
  slotBookings  SlotBooking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roleId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ─────────────────────────────────────────────
// PAYMENTS & STATS
// ─────────────────────────────────────────────

model PaymentYear {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  year      Int
  status    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, year])
  @@index([userId])
}

model Stats {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  squat    Float
  bench    Float
  deadlift Float

  // Permet de tracker l'évolution dans le temps
  recordedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([recordedAt])
}

// ─────────────────────────────────────────────
// PROGRAMS
// ─────────────────────────────────────────────

model Program {
  id      String @id @default(uuid())
  name    String
  fileUri String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ─────────────────────────────────────────────
// COURSES
// ─────────────────────────────────────────────

model Course {
  id              String   @id @default(uuid())
  title           String
  description     String?
  startAt         DateTime
  durationMinutes Int
  maxParticipants Int

  coachId String?
  coach   User?   @relation("CoachCourses", fields: [coachId], references: [id], onDelete: SetNull)

  registrations Registration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([coachId])
  @@index([startAt])
}

model Registration {
  id       String @id @default(uuid())
  userId   String
  courseId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

// ─────────────────────────────────────────────
// SHOP
// ─────────────────────────────────────────────

model Product {
  id       String @id @default(uuid())
  name     String
  price    Float  @default(0)
  imageUri String @default("productImage/default.png")

  stocks     ProductStock[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductStock {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  size      String
  quantity  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, size])
  @@index([productId])
  @@index([size])
}

model Order {
  id     String      @id @default(uuid())
  userId String
  user   User        @relation(fields: [userId], references: [id])
  items  OrderItem[]
  total  Float

  status OrderStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  size      String
  quantity  Int
  price     Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
}

// ─────────────────────────────────────────────
// COACHING SLOTS
// ─────────────────────────────────────────────

model CoachingSlot {
  id        String   @id @default(uuid())
  startTime DateTime
  endTime   DateTime
  coachId   String

  coach    User          @relation("CoachSlots", fields: [coachId], references: [id])
  bookings SlotBooking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([coachId])
  @@index([startTime])
}

model SlotBooking {
  id     String @id @default(uuid())
  slotId String
  userId String

  slot CoachingSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  bookedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([slotId, userId])
  @@index([slotId])
  @@index([userId])
}