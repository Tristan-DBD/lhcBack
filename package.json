{
  "name": "back",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "npx dotenv-cli -e .env.dev -- nodemon",
    "prod": "npx dotenv-cli -e .env.prod -- ts-node src/index.ts",
    "test": "npx dotenv-cli -e .env.test -- jest --runInBand --forceExit --detectOpenHandles --verbose",
    "test:prod": "npx dotenv-cli -e .env.prod -- jest --runInBand --forceExit --coverage",
    "test:coverage": "npx dotenv-cli -e .env.dev -- jest --runInBand --forceExit --coverage --coverageReporters=html --coverageReporters=text",
    "test:coverage:ci": "npx dotenv-cli -e .env.test -- jest --runInBand --forceExit --coverage --coverageReporters=html --coverageReporters=text",
    "migrate:test": "npx dotenv-cli -e .env.test -- npx prisma migrate dev",
    "migrate:dev": "npx dotenv-cli -e .env.dev -- prisma migrate dev",
    "migrate:prod": "npx dotenv-cli -e .env.prod -- prisma migrate deploy",
    "generate:prisma": "npx dotenv-cli -e .env.test -- prisma generate",
    "generate:prisma:prod": "npx dotenv-cli -e .env.prod -- prisma generate",
    "postinstall": "npx prisma generate",
    "build": "tsc",
    "start": "NODE_ENV=prod node dist/src/index.js",
    "deploy:prod": "npm run migrate:prod && npm run build",
    "seed": "npx dotenv-cli -e .env.dev -- ts-node prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/helmet": "^0.0.48",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.7.4",
    "prisma": "^7.1.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsoa": "^6.6.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.2.0",
    "@supabase/supabase-js": "^2.90.1",
    "@types/redis": "^4.0.10",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "redis": "^5.10.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "zod": "^4.2.1"
  }
}